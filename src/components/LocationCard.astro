---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
    image: ImageMetadata;
    title: string;
}
const { title, image } = Astro.props;
---

<div class="flex flex-col p-2 md:p-4 lg:p-5 w-44 md:w-56 lg:w-72 max-h-fit">
    <Image
        src={image}
        alt={title}
        class="size-16 md:size-20 lg:size-38 self-center object-contain"
        format="webp"
    />
    <h3 class="text-center text-2xl md:text-3xl lg:text-5xl">{title}</h3>
    <p class="text-xs md:text-md lg:text-xl">
        <slot />
    </p>
</div>
