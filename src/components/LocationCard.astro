---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
    image: ImageMetadata;
    title: string;
}
const { title, image } = Astro.props;
---

<div class="flex flex-col p-2 md:p-4 lg:p-5 w-52 md:w-92 max-h-fit">
    <Image
        src={image}
        alt={title}
        class="size-16 md:size-38 self-center object-contain"
        format="webp"
        loading="lazy"
    />
    <h3 class="text-center text-3xl md:text-5xl">{title}</h3>
    <p class="text-md md:text-xl">
        <slot />
    </p>
</div>
