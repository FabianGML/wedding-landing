---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
    image: ImageMetadata;
    title: string;
}
const { title, image } = Astro.props;
---

<div class="flex flex-col p-5 w-72 max-h-72">
    <Image
        src={image}
        alt={title}
        class="size-32 self-center object-contain"
        format="webp"
    />
    <h3 class="text-5xl">{title}</h3>
    <p class="text-xl">
        <slot />
    </p>
</div>
