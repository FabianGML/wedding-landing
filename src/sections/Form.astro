---
import SectionContainer from "@/components/SectionContainer.astro";
import Input from "@/components/Input.astro";
import { Image } from "astro:assets";
// ----- Images -----
import mobileForm from "@/assets/images/form/mobileForm.webp";
import form from "@/assets/images/form/form.webp";
import buttonImg from "@/assets/images/form/button.webp";
import { getI18N } from "@/i18n";

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale });
---

<SectionContainer>
    <p class="text-secondary italic p-10 md:text-lg lg:px-32 lg:text-xl">
        {i18n.FORM_TEXT}
    </p>
    <div
        class="relative lg:h-1/2 lg:w-3/5 lg:flex lg:justify-center lg:mx-auto"
    >
        <Image
            src={mobileForm}
            alt="form background"
            class="w-full lg:hidden"
        />
        <Image
            src={form}
            alt="form background"
            class="w-full hidden lg:block"
        />
        <form
            class="absolute w-11/12 left-1/2 -translate-x-1/2 top-1/4 h-9/12 lg:h-5/12 lg:top-4/7"
        >
            <div class="flex flex-col h-full justify-evenly items-center">
                <div
                    class="flex flex-col lg:flex-row h-1/2 justify-evenly items-center"
                >
                    <Input
                        label={i18n.FORM_NAME_INPUT}
                        name="name"
                        type="text"
                        placeholder="Pamela Gutiérrez..."
                    />
                    <Input
                        label={i18n.FORM_PERSONS_INPUT}
                        name="persons"
                        type="number"
                        placeholder="2"
                    />
                </div>
                <button
                    class="w-full relative h-24 max-w-48 group cursor-pointer lg:max-w-32"
                >
                    <Image
                        src={buttonImg}
                        alt="submit button"
                        class="transition-all duration-200 group-hover:scale-105 group-hover:brightness-90 group-active:scale-95"
                    />
                    <span
                        class="absolute top-1/2 -translate-y-5 text-4xl transition-all duration-200 group-hover:scale-105 group-active:scale-95"
                        class:list={currentLocale === "de"
                            ? "-translate-x-10"
                            : "-translate-x-8"}
                    >
                        {i18n.BUTTON_TEXT}
                    </span>
                </button>
            </div>
        </form>
    </div>
</SectionContainer>

<style>
    span {
        font-family: "Madina", ui-serif, Georgia, serif;
    }
</style>
