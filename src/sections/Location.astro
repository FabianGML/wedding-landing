---
import LocationGallery from "@/components/LocationGallery.astro";
import SectionContainer from "@/components/SectionContainer.astro";
import { getI18N } from "@/i18n/index";
import { Image } from "astro:assets";
import LocationCard from "@/components/LocationCard.astro";
// --- Imagenes ---
import marco from "@/assets/images/location/marco.webp";
import marcoVertical from "@/assets/images/location/marcoVertical.webp";
import hacienda from "@/assets/images/location/hacienda.webp";
import dressCode from "@/assets/images/location/dressCode.webp";
import horario from "@/assets/images/location/horario.webp";

const { currentLocale } = Astro;
const i18n = getI18N({ currentLocale });
---

<section>
    <!-- Mobile layout (< md) — marcoVertical.webp -->
    <div class="lg:hidden relative">
        <Image src={marcoVertical} alt="Marco" class="w-full h-auto" />
        <h3
            class="text-4xl md:text-5xl absolute top-[8%] left-1/2 -translate-x-1/2"
        >
            {i18n.LOCATION_TITLE}
        </h3>
        <div
            class="absolute flex flex-col items-center justify-evenly h-9/12 w-full gap-1 top-[15%] left-1/2 md:left-1/2 -translate-x-1/2"
        >
            <LocationCard
                title={i18n.LOCATION_SECTION_TITLE_3}
                image={horario}
            >
                {i18n.LOCATION_SECTION_DESC_1}
                <div>
                    <a
                        href="https://www.google.com/maps/place/Templo+de+Nuestra+Se%C3%B1ora+de+Los+%C3%81ngeles/data=!4m2!3m1!1s0x869bc83f7bd8013b:0x14e018a00b7410bb?sa=X&ved=1t:242&ictx=111"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm lg:text-lg bg-accent rounded-lg px-1 py-0.5 lg:px-2 lg:py-1 transition-colors duration-200 text-white hover:cursor-pointer hover:bg-accent/60 hover:text-secondary block w-fit"
                    >
                        Templo de Nuestra Señora de los Ángeles
                    </a>
                </div>
                <span>{i18n.LOCATION_SECTION_DESC_1_1}</span>
                <span>{i18n.LOCATION_SECTION_DESC_1_2}</span>
                <div class="flex gap-4 items-center">
                    <a
                        href="https://www.google.com/maps?q=Hacienda+La+Galera,+Durango,+Dgo.+México"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm lg:text-lg bg-accent rounded-lg px-1 py-0.5 lg:px-2 lg:py-1 transition-colors duration-200 text-white hover:cursor-pointer hover:bg-accent/60 hover:text-secondary block w-fit"
                    >
                        Hacienda La Galera
                    </a>
                </div>
                <span>{i18n.LOCATION_SECTION_DESC_1_3}</span>
            </LocationCard>
            <LocationCard
                title={i18n.LOCATION_SECTION_TITLE_2}
                image={dressCode}
            >
                <data set:html={i18n.LOCATION_SECTION_DESC_2} />
            </LocationCard>
        </div>
    </div>

    <!-- Desktop layout (md+) — marco.webp -->
    <div
        class="hidden lg:flex flex-col lg:flex-row lg:flex-row gap-10 relative"
    >
        <Image src={marco} alt="Marco" class="w-full h-full" />
        <h3
            class="text-4xl lg:text-7xl absolute top-1/5 left-1/2 -translate-x-1/2"
        >
            {i18n.LOCATION_TITLE}
        </h3>
        <div
            class="absolute flex top-[26%] justify-evenly left-1/14 w-12/14 lg:left-0 lg:w-full"
        >
            <LocationCard
                title={i18n.LOCATION_SECTION_TITLE_1}
                image={hacienda}
            >
                {i18n.LOCATION_SECTION_DESC_1}
                <div class="flex gap-4 items-center">
                    <a
                        href="https://www.google.com/maps/place/Templo+de+Nuestra+Se%C3%B1ora+de+Los+%C3%81ngeles/data=!4m2!3m1!1s0x869bc83f7bd8013b:0x14e018a00b7410bb?sa=X&ved=1t:242&ictx=111"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm lg:text-lg bg-accent rounded-lg px-1 py-0.5 lg:px-2 lg:py-1 transition-colors duration-200 text-white hover:cursor-pointer hover:bg-accent/60 hover:text-secondary block w-fit"
                    >
                        Templo de nuestra señora de los Ángeles
                    </a>
                    <span class="text-sm lg:text-lg text-gray-500"
                        >17:45 hrs</span
                    >
                </div>
                <span>{i18n.LOCATION_SECTION_DESC_1_1}</span>
                <div class="flex gap-4 items-center">
                    <a
                        href="https://www.google.com/maps?q=Hacienda+La+Galera,+Durango,+Dgo.+México"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm lg:text-lg bg-accent rounded-lg px-1 py-0.5 lg:px-2 lg:py-1 transition-colors duration-200 text-white hover:cursor-pointer hover:bg-accent/60 hover:text-secondary block w-fit"
                    >
                        Hacienda La Galera
                    </a>
                    <span class="text-sm lg:text-lg text-gray-500"
                        >20:00 hrs</span
                    >
                </div>
            </LocationCard>
            <LocationCard
                title={i18n.LOCATION_SECTION_TITLE_2}
                image={dressCode}
            >
                <data set:html={i18n.LOCATION_SECTION_DESC_2} />
            </LocationCard>
            <LocationCard title={i18n.LOCATION_SECTION_TITLE_3} image={horario}>
                {i18n.LOCATION_SECTION_DESC_3}
            </LocationCard>
        </div>
    </div>
    <LocationGallery />
</section>

<style>
    .map-container {
        position: relative;
        width: 100%;
        height: 450px;
        border-radius: 16px;
        border: 3px solid var(--color-accent);
        background-color: #fff;
        box-shadow:
            0 4px 12px rgba(212, 181, 167, 0.2),
            0 8px 24px rgba(0, 0, 0, 0.08);
        padding: 2px;
    }

    .map-container::before {
        content: "";
        position: absolute;
        top: 12px;
        left: 12px;
        right: 12px;
        bottom: 12px;
        border: 2px solid var(--color-accent);
        border-radius: 8px;
        z-index: 10;
        pointer-events: none;
        opacity: 0.6;
    }

    .map-container iframe {
        border-radius: 8px;
    }

    @media (min-width: 768px) {
        .map-container {
            height: 500px;
        }
    }

    @media (min-width: 1024px) {
        .map-container {
            height: 550px;
        }
    }
</style>
